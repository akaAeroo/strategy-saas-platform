# ============================================
# 智能策略平台 - 后端配置
# 复制此文件为 .env 并填写实际配置
# ============================================

# 服务端口
PORT=3001

# ============================================
# 公司云端数据API配置
# ============================================
AUDIENCE_API_URL=https://your-company-audience-api.com
AUDIENCE_API_KEY=your_audience_api_key
AUDIENCE_API_TIMEOUT=30000

# ============================================
# 云端大模型API配置
# 支持 OpenAI / Claude / 文心一言 / 通义千问等
# ============================================

# OpenAI 配置
OPENAI_API_KEY=sk-your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# 或 Claude 配置
ANTHROPIC_API_KEY=sk-ant-your_claude_key
ANTHROPIC_MODEL=claude-3-opus-20240229

# 或国内模型（文心/通义/智谱）
BAIDU_API_KEY=your_baidu_key
BAIDU_SECRET_KEY=your_baidu_secret

ALIBABA_API_KEY=your_alibaba_key
ALIBABA_MODEL=qwen-max

# 默认使用的模型提供商: openai | anthropic | baidu | alibaba
AI_PROVIDER=openai

# ============================================
# AI诊断配置
# ============================================
AI_DIAGNOSIS_TEMPERATURE=0.3
AI_DIAGNOSIS_MAX_TOKENS=2000

# ============================================
# 数据存储配置
# ============================================
DATA_DIR=./diagnoses
CACHE_TTL=300

# ============================================
# CORS 配置（开发环境）
# ============================================
CORS_ORIGIN=http://localhost:5173
