# ============================================
# 智能策略平台 - 后端配置
# 复制此文件为 .env 并填写实际配置
# ============================================

# 服务端口
PORT=3001

# ============================================
# 公司云端数据API配置
# ============================================
AUDIENCE_API_URL=https://your-company-audience-api.com
AUDIENCE_API_KEY=your_audience_api_key
AUDIENCE_API_TIMEOUT=30000

# ============================================
# AI模型配置
# 支持: openai | anthropic | moonshot | zhipu | baidu | alibaba | ollama
# ============================================

# 默认AI提供商
AI_PROVIDER=openai

# -------------------------------------------
# OpenAI 配置 (GPT-4)
# -------------------------------------------
OPENAI_API_KEY=sk-your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# -------------------------------------------
# Anthropic Claude 配置
# -------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_claude_key
ANTHROPIC_MODEL=claude-3-opus-20240229

# -------------------------------------------
# Kimi (Moonshot) 配置
# 获取API Key: https://platform.moonshot.cn/
# -------------------------------------------
MOONSHOT_API_KEY=sk-your_moonshot_key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-128k

# -------------------------------------------
# 智谱 AI (ChatGLM) 配置
# 获取API Key: https://open.bigmodel.cn/
# -------------------------------------------
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4

# -------------------------------------------
# MiniMax 配置
# 获取API Key: https://www.minimax.chat
# -------------------------------------------
MINIMAX_API_KEY=sk-your-minimax-key
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-01

# -------------------------------------------
# 量化派 OpenCode - 星探·源曦 (内网部署)
# 网关地址: https://gateway.xrtan.cn:5029
# API地址: http://10.4.16.154:5029/v1
# 获取API Key: 运行 opencode-configuration.sh 配置
# -------------------------------------------
OPENCODE_API_KEY=your-opencode-key-from-gateway
OPENCODE_BASE_URL=http://10.4.16.154:5029/v1
OPENCODE_MODEL=quantgroup/xingtan
OPENCODE_PROVIDER_ID=quantgroup

# -------------------------------------------
# 百度文心一言 配置
# -------------------------------------------
BAIDU_API_KEY=your_baidu_key
BAIDU_SECRET_KEY=your_baidu_secret

# -------------------------------------------
# 阿里通义千问 配置
# -------------------------------------------
ALIBABA_API_KEY=your_alibaba_key
ALIBABA_MODEL=qwen-max

# -------------------------------------------
# 本地 Ollama 配置
# 无需API Key，需要本地安装 Ollama: https://ollama.com/
# -------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ============================================
# AI诊断配置
# ============================================
AI_DIAGNOSIS_TEMPERATURE=0.3
AI_DIAGNOSIS_MAX_TOKENS=2000

# ============================================
# 数据存储配置
# ============================================
DATA_DIR=./diagnoses
CACHE_TTL=300

# ============================================
# CORS 配置（开发环境）
# ============================================
CORS_ORIGIN=http://localhost:5173
